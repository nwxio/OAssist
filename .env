LLM_PROVIDER=auto
LLM_FALLBACK_ORDER=ollama,openai,deepseek
LLM_TEMPERATURE=0.2
REQUEST_TIMEOUT_SECONDS=60

OPENAI_BASE_URL=https://api.openai.com/v1
